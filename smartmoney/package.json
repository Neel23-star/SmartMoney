{
  "name": "smartmoney-desktop",
  "version": "1.0.0",
  "description": "Smart Money Screener — Institutional activity detector for Indian markets",
  "main": "electron-main.js",
  "scripts": {
    "build-frontend": "cd frontend && npm run build",
    "start": "electron .",
    "package": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.smartmoney.screener",
    "productName": "Smart Money Screener",
    "win": {
      "target": "nsis",
      "icon": "frontend/public/icon-512.png"
    },
    "files": [
      "electron-main.js",
      "splash.html",
      "backend/**",
      "frontend/dist/**",
      "!backend/node_modules/.cache"
    ],
    "extraResources": [],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
